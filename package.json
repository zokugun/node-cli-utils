{
	"name": "@zokugun/cli-utils",
	"description": "Utils for CLI app",
	"version": "0.2.1",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"license": "MIT",
	"homepage": "https://github.com/zokugun/node-cli-utils",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zokugun/node-cli-utils.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/node-cli-utils/discussions/categories/issue-triage"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./lib/esm/index.mjs",
			"require": "./lib/cjs/index.cjs"
		},
		"./ansi-colors": {
			"import": "./lib/esm/ansi-colors.mjs",
			"require": "./lib/cjs/ansi-colors.cjs"
		},
		"./cli-spinners": {
			"import": "./lib/esm/cli-spinners.mjs",
			"require": "./lib/cjs/cli-spinners.cjs"
		},
		"./commander": {
			"import": "./lib/esm/commander.mjs",
			"require": "./lib/cjs/commander.cjs"
		},
		"./enquirer": {
			"import": "./lib/esm/enquirer.mjs",
			"require": "./lib/cjs/enquirer.cjs"
		},
		"./logger": {
			"import": "./lib/esm/logger.mjs",
			"require": "./lib/cjs/logger.cjs"
		}
	},
	"main": "lib/cjs/index.cjs",
	"module": "lib/esm/index.mjs",
	"typesVersions": {
		"*": {
			".": [
				"./lib/cjs/index.d.cts"
			],
			"ansi-colors": [
				"./lib/cjs/ansi-colors.d.cts"
			],
			"cli-spinners": [
				"./lib/cjs/cli-spinners.d.cts"
			],
			"commander": [
				"./lib/cjs/commander.d.cts"
			],
			"enquirer": [
				"./lib/cjs/enquirer.d.cts"
			],
			"logger": [
				"./lib/cjs/logger.d.cts"
			]
		}
	},
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"build": "npm run clean && npm run build:lib",
		"build:lib": "tsc-leda generate",
		"build:package": "tsc-leda update-package",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"clean": "rimraf lib .src",
		"compile:src": "tsc -p src",
		"lint": "xo",
		"lint:all": "fixpack && npm audit && npm run ci:lint && npm run lint",
		"lint:fix": "xo --fix",
		"postinstall": "patch-package",
		"prepack": "npm run build",
		"prepare": "husky; fixpack || true",
		"release": "release-it",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run",
		"update:deps": "taze",
		"watch:build": "tsc-watch -p src --onSuccess 'npm run build'",
		"watch:src": "tsc-watch -p src"
	},
	"dependencies": {
		"@commander-js/extra-typings": "14.0.0",
		"@zokugun/log-update-plus": "0.1.1",
		"ansi-colors": "4.1.3",
		"cli-spinners": "3.4.0",
		"commander": "14.0.3",
		"enquirer": "2.4.1",
		"patch-package": "8.0.1"
	},
	"devDependencies": {
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@types/node": "20.19.39",
		"@zokugun/tsc-leda": "0.3.1",
		"fixpack": "4.0.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"release-it": "20.0.0-1",
		"taze": "19.11.0",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3",
		"xo": "0.60.0"
	},
	"keywords": []
}
